---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<footer>
  <Wrapper class="py-8">
    <div class="max-w-2xl mx-auto text-center">
      <Text tag="p" variant="textSM" class="text-muted-foreground">
        由 <a target="_blank" rel="noopener noreferrer" class="text-foreground hover:text-muted-foreground" href="https://v2rayn.eu.cc">V2RayN 中文指南</a> 团队
        基于 <a target="_blank" rel="noopener noreferrer" class="text-foreground hover:text-muted-foreground" href="https://github.com/michael-andreuzza/bearnie">Bearnie UI</a> 构建。
      </Text>
      
      <div class="mt-6 flex flex-wrap justify-center gap-x-6 gap-y-2">
        <a href="/legal/about-us" class="text-sm text-muted-foreground hover:text-foreground transition-colors">关于我们</a>
        <a href="/legal/links" class="text-sm text-muted-foreground hover:text-foreground transition-colors">友情链接</a>
        <a href="/legal/disclaimer" class="text-sm text-muted-foreground hover:text-foreground transition-colors">免责声明</a>
        <a href="/legal/terms" class="text-sm text-muted-foreground hover:text-foreground transition-colors">服务条款</a>
        <a href="/legal/privacy" class="text-sm text-muted-foreground hover:text-foreground transition-colors">隐私政策</a>
      </div>
    </div>
  </Wrapper>
</footer>
