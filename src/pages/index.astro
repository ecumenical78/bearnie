---
import { AstroSeo } from "@astrolib/seo";
// Assets
import Logo from "@/components/assets/Logo.astro";
// Foundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/ui/button/Button.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { siteConfig } from "@/config/site";

const canonical = `${siteConfig.url}${Astro.url.pathname === "/" ? "" : Astro.url.pathname}`;
---

<AstroSeo
  title="V2RayN 客户端下载、安装配置与完整使用教程 | V2RayN 中文指南"
  description="v2rayn.eu.cc 为您提供最新版 V2RayN Windows 客户端下载、详细的图文安装教程、服务器节点配置指南及常见连接报错的解决方案。"
  canonical={canonical}
  openGraph={{
    url: canonical,
    title: "V2RayN 客户端下载、安装配置与完整使用教程 | V2RayN 中文指南",
    description:
      "v2rayn.eu.cc 为您提供最新版 V2RayN Windows 客户端下载、详细的图文安装教程、服务器节点配置指南及常见连接报错的解决方案。",
    site_name: siteConfig.name,
    type: "website",
    locale: "zh_CN",
    images: [
      {
        url: siteConfig.ogImage,
        width: 1200,
        height: 630,
        alt: `${siteConfig.name} Open Graph image`,
        type: "image/jpeg",
      },
    ],
  }}
  twitter={{
    cardType: "summary_large_image",
    site: siteConfig.author.twitter,
    handle: siteConfig.author.twitter,
  }}
/>
<BaseLayout
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteConfig.name,
    description:
      "v2rayn.eu.cc 为您提供最新版 V2RayN Windows 客户端下载、详细的图文安装教程、服务器节点配置指南及常见连接报错的解决方案。",
    url: siteConfig.url,
    publisher: {
      "@type": "Organization",
      name: siteConfig.name,
      url: siteConfig.url,
      logo: {
        "@type": "ImageObject",
        url: siteConfig.ogImage,
      },
    },
    sameAs: [siteConfig.author.twitter],
  }}
>
  <section>
    <Wrapper
      class="standard"
      class="py-12 lg:h-[calc(100vh-11.5rem)] flex flex-col justify-center"
    >
      <!-- Hero Section -->
      <div class="max-w-sm text-center mx-auto text-balance">
        <Logo class="size-12 lg:size-20 mx-auto" />
        <Text
          tag="h1"
          variant="textLG"
          class="font-medium tracking-tight mt-12"
        >
          探索最新的 V2RayN<br /> 教程与使用指南
          <Text tag="p" variant="textSM" class="text-muted-foreground mt-4">
            为您提供最新版 V2RayN Windows 客户端下载、详细的图文安装教程、服务器节点配置指南及常见连接报错的解决方案。无论您是新手上手还是进阶路由分流，都能在这里找到最全面的 V2RayN 使用技巧。
          </Text>

          <div class="flex items-center gap-2.5 mt-12 justify-center">
            <Button href="/docs" size="default">阅读教程</Button>
            <Button href="/blog" variant="outline" size="default"
              >最新文章</Button
            >
          </div>
          <code class="mt-8 block text-xs text-muted-foreground font-mono">
            科学上网客户端指北
          </code>
        </Text>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
