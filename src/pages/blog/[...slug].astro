---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Text from "@/components/fundations/elements/Text.astro";

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// 2. For your template, you can get the entry directly from the prop
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout>
  <article class="py-12 lg:py-24">
    <Wrapper class="standard max-w-3xl">
      <header class="mb-12 border-b pb-8">
        <Text tag="p" variant="textSM" class="text-neutral-500 mb-4">
          <time datetime={entry.data.pubDate.toISOString()}>
            {entry.data.pubDate.toLocaleDateString("zh-CN", {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          {entry.data.author && <span class="ml-2">作者：{entry.data.author}</span>}
        </Text>
        
        <Text tag="h1" variant="displaySM" class="font-medium tracking-tight mb-4">
          {entry.data.title}
        </Text>
        
        <Text tag="p" variant="textLG" class="text-muted-foreground">
          {entry.data.description}
        </Text>
        
        {entry.data.tags && entry.data.tags.length > 0 && (
          <div class="flex gap-2 mt-6">
            {entry.data.tags.map(tag => (
              <span class="bg-primary/10 text-primary text-xs px-2.5 py-1 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="prose dark:prose-invert prose-neutral max-w-none">
        <Content />
      </div>
    </Wrapper>
  </article>
</BaseLayout>
