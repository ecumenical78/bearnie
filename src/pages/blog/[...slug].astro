---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Text from "@/components/fundations/elements/Text.astro";
import { AstroSeo } from "@astrolib/seo";
import { siteConfig } from "@/config/site";

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// 2. For your template, you can get the entry directly from the prop
const { entry } = Astro.props;
const { Content } = await entry.render();

const canonical = `${siteConfig.url}/blog/${entry.slug}/`;
const title = `${entry.data.title} | ${siteConfig.name}`;
const description = entry.data.description || siteConfig.description;
---

<AstroSeo
  title={title}
  description={description}
  canonical={canonical}
  openGraph={{
    url: canonical,
    title: title,
    description: description,
    site_name: siteConfig.name,
    type: "article",
    article: {
      publishedTime: entry.data.pubDate.toISOString(),
      authors: [entry.data.author || "V2RayN 中文指南"],
      tags: entry.data.tags || [],
    },
    images: [
      {
        url: siteConfig.ogImage,
        width: 1200,
        height: 630,
        alt: title,
        type: "image/jpeg",
      },
    ],
  }}
  twitter={{
    cardType: "summary_large_image",
    site: siteConfig.author.twitter,
    handle: siteConfig.author.twitter,
  }}
/>
<BaseLayout
  structuredData={{
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: entry.data.title,
    description: description,
    datePublished: entry.data.pubDate.toISOString(),
    author: {
      "@type": "Person",
      name: entry.data.author || "V2RayN 中文指南",
    },
    publisher: {
      "@type": "Organization",
      name: siteConfig.name,
      logo: {
        "@type": "ImageObject",
        url: `${siteConfig.url}/favicon.svg`,
      },
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": canonical,
    },
    keywords: entry.data.tags?.join(", ") || "",
  }}
>
  <article class="py-12 lg:py-24">
    <Wrapper class="standard max-w-3xl">
      <header class="mb-12 border-b pb-8">
        <Text tag="p" variant="textSM" class="text-neutral-500 mb-4">
          <time datetime={entry.data.pubDate.toISOString()}>
            {entry.data.pubDate.toLocaleDateString("zh-CN", {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          {entry.data.author && <span class="ml-2">作者：{entry.data.author}</span>}
        </Text>
        
        <Text tag="h1" variant="displaySM" class="font-medium tracking-tight mb-4">
          {entry.data.title}
        </Text>
        
        <Text tag="p" variant="textLG" class="text-muted-foreground">
          {entry.data.description}
        </Text>
        
        {entry.data.tags && entry.data.tags.length > 0 && (
          <div class="flex gap-2 mt-6">
            {entry.data.tags.map(tag => (
              <span class="bg-primary/10 text-primary text-xs px-2.5 py-1 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="prose dark:prose-invert prose-neutral max-w-none">
        <Content />
      </div>
    </Wrapper>
  </article>
</BaseLayout>
